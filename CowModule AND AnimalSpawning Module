-- | Services | --
local replicatedStorage = game:GetService("ReplicatedStorage")
local pathFindingService = game:GetService("PathfindingService")
-- | Variables | -- 
local params = 	{AgentRadius = 4,
	AgentHeight = 6,
	AgentCanJump = true} --Settings i'm going to use for pathfinding
local randomModule = require(replicatedStorage.ModuleScripts.RandomChanceModule) -- very simple module I made just to return true if it generates a number lower or equal to the one you sent. So I can get like RNG
-- | Constants | --
local cowRange = 25
local cowModule = {}
cowModule.__index = cowModule -- Ik yall know what this means but, basically setting up hey if your reference this and it doesn't exist then look for it in the cowModule.
function cowModule.new(cowModel) -- creates a new instance of the cow
	local self = setmetatable({},cowModule) -- sets up the metatable so when you index it, it will look into cowModule
	self.Model = cowModel
	self.Humanoid = cowModel:FindFirstChild("Humanoid") --just a bunch of setting up stuff here for later
	self.HumanoidRootPart = cowModel:FindFirstChild("HumanoidRootPart")
	self.SkinPrompt = cowModel:FindFirstChild("HumanoidRootPart"):FindFirstChild("SkinCowPrompt")
	self.BillBoardGui =  self.HumanoidRootPart:FindFirstChild("BillboardGui")
	self.HealthBarGreen = self.BillBoardGui:FindFirstChild("HealthBar_Green")
	self.HealthBarRed = self.BillBoardGui:FindFirstChild("HealthBar_Red")
	self.Range = cowRange
	self.Path = pathFindingService:CreatePath(params) -- individual path for each cow
	return self
end
function cowModule:MoveToRandom(multiplier)
	local range = self.Range 
	if multiplier then -- if i want them to move extra far for some reason I have this, like if they get hurt
		range *= multiplier
	end
	local offset = Vector3.new(math.random(-range,range),0,math.random(-range,range))
	local randomDestination = self.HumanoidRootPart.Position +offset -- basically just move them to a random spot
	self.Path:ComputeAsync(self.HumanoidRootPart.Position, randomDestination) -- actually computes the path
	if self.Path.Status ~= Enum.PathStatus.Success then -- if it fails then exit
		return
	end

	for _, waypoint in ipairs(self.Path:GetWaypoints()) do -- for each waypoint that is generated we move to each one unless we need to jump or it takes to long to finish the move(5 seconds)
		if waypoint.Action == Enum.PathWaypointAction.Jump then
			self.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
		end
		self.Humanoid:MoveTo(waypoint.Position)
		local reachedDestinationOnTime = self.Humanoid.MoveToFinished:Wait(5)
		if not reachedDestinationOnTime then -- if it takes too long for some reason just exit the function
			return
		end
	end
end
function cowModule:DeathMoo() -- silly thing where the cow slowly moos on death
	local sound = self..Mesh.Sound
	sound.PlaybackSpeed = 0.8
	sound:Play()

end
function cowModule:OnDeath() -- IF they die, health bar disappears and you can skin the cow and also they get flipped on their side
	self:DeathMoo()
	self.BillBoardGui.Enabled = false
	self.SkinPrompt.Enabled = true
	self.Model.Mesh.CanCollide = false
	self.HumanoidRootPart.CFrame = self.HumanoidRootPart.CFrame * CFrame.Angles(0,0,math.rad(90)) --- super simple cframe rotation
end
function cowModule:SpeedBoost() -- Cows Speed up when they are hit 
	if randomModule.percentChanceToHappen(20) then
		self:Moo()
	end
	task.spawn(function() -- spawn a function that doesn't hinder the current thread that adds and removes a boost in walkspeed
		self.Humanoid.WalkSpeed += 3.5 
		task.wait(2)
		self.Humanoid.WalkSpeed -= 3.5 
	end)
end
function cowModule:OnHealthChanged() -- this fires when the humanoid.HealthChanged event happe s
	if self.Humanoid.Health  ~= self.Humanoid.MaxHealth then 
		self.BillBoardGui.Enabled = true
		self.HealthBarGreen.Size = UDim2.new(self.Humanoid.Health/self.Humanoid.MaxHealth,0,self.HealthBarGreen.Size.Y.Scale,0) -- update to a percentage
		self:SpeedBoost() -- calls the speed boost
		self:MoveToRandom(2) -- they move farther because they are hurt
	else 
		self.BillBoardGui.Enabled = false
	end
end
function cowModule:Initiate() -- this just sets up the connections that keep the health updated and that tell when the cow dies so we can do the OnDeath function
	self.Humanoid.Died:Connect(function()
		self:OnDeath()
	end)
	self.Humanoid.HealthChanged:Connect(function()
		self:OnHealthChanged()
	end)
end
function cowModule:Moo(volume) -- silly thing that just makes the cow moo, i added option to set volume but not sure if I'm gonna use it
	self.Model.Mesh.Sound.Volume = volume or 0.25
	self.Model.Mesh.Sound:Play()
end
function cowModule:StartBehavior() -- the loop that as long as the cow is alive they Move and Moo every 1-5 seconds
	self.SkinPrompt.Enabled = false
	self.BillBoardGui.Enabled = false --Disables things I don't want players to see yet
	self.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true) -- so they can Jump if they want to when pathfinding
	task.spawn(function()
		while self.Humanoid.Health > 0  do
			if randomModule.percentChanceToHappen(15) then -- the module i was talking about, 15% chance to moo when moving
				self:Moo()
			end
			self:MoveToRandom()
			task.wait(math.random(1,5))
		end
	end
end
return cowModule
