-- | Services | -- 
local replicatedStorage = game:GetService("ReplicatedStorage")
--| Variables | -- 
local animalSpawnerPartFolder = game.Workspace.SpawnerPartsFolder.AnimalSpawnerPartFolder -- for all the AnimalSpawnParts
local spawnerPartFolder = game.Workspace.SpawnerPartsFolder.CropSpawnerTripletFolder -- for crop spawning
local NaturalResourceStructureFolder = replicatedStorage.NaturalResourceStructureFolder -- Holds 
