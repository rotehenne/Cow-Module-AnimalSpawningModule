local cowModule = require(replicatedStorage.ModuleScripts.CowModule) -- the cow module above
local randomModule = require(replicatedStorage.ModuleScripts.RandomChanceModule) -- same random module
-- | Constants | --
local maxCowsOnServer = 130 -- spawn cap
local minCows = 1 -- minmum of cows to spawn per spawner
local maxCows = 4 -- maximum of cows to spawn per spawner
local spawnerModule = {}

function spawnerModule.setAllInvisible() -- All SpawnerParts Before the game starts are visible incase I want to manipulate them in studio, this makes them all invisible
	for i , model in ipairs(spawnerPartFolder:GetChildren()) do
		if model:IsA("Model") then
			for i, child in ipairs(model:GetChildren()) do
				if child:IsA("Part") then
					child.Transparency  = 1
					if child:FindFirstChild("Highlight") then
						child:FindFirstChild("Highlight"):Destroy()
					end
				end
			end
		end
	end

	for i , model in ipairs(animalSpawnerPartFolder:GetChildren()) do -- sets animalSpawners Invisible
		if model:IsA("Model") then

			for i, child in ipairs(model:GetChildren()) do -- creates an array
				if child:IsA("Part") then
					child.Transparency  = 1
					if child:FindFirstChild("Highlight") then
						child:FindFirstChild("Highlight"):Destroy()

					end
				end
			end
		end
	end
end
local function getCowsCount() -- just a little function to get how many cows are on the server in total
	local Cowcount = 0
	for i, child in ipairs(game.Workspace.Map.Animals:GetChildren()) do
		if child.Name == "Cow_Model" then
			Cowcount +=1
		end
	end
	return Cowcount
end
local function spawnCowToLocation(cowClone, cframe) -- this uses the COW MODULE to create a new cowInstance and put it at the spawn part
	cowClone.Parent = workspace.Map.Animals
	cowClone:PivotTo(cframe) --  moves the entire model to the CFRAME
	local cow = cowModule.new(cowClone)
	cow:Initiate() -- sets up the connections in the module -->Health changed and OnDeath
	cow:StartBehavior() -- sets up the moving and mooing behavior
end
function spawnerModule.CheckIfToSpawnNewResources()
	for i , spawnerModel in ipairs(spawnerPartFolder:GetChildren()) do -- this is for food and crops IGNORE this  and go to CONTINUED if you want but i'll comment anyways
		--For Crops
		if spawnerModel:IsA("Model") then -- starts as models called crop triplets then for each part inside it moves that randomly choosen crop either Corn or Wheat to the part
			local desiredCrop = NaturalResourceStructureFolder:FindFirstChild("Wheat_Plant") -- chooses what crop
			if randomModule.percentChanceToHappen(50) then
				desiredCrop = NaturalResourceStructureFolder:FindFirstChild("Corn_Stalk")
			end
			if spawnerModel.Name == "Fiber Spawn Triplet" then  -- unless it is dedicated Fiber Part then we spawn fiberplants
				desiredCrop = NaturalResourceStructureFolder:FindFirstChild("Fiber_Plant")
			end
			for i, spawnerPart in ipairs(spawnerModel:GetChildren()) do
				if spawnerPart:IsA("Part") then  --
					local hasStuffSpawnedAlready = false
					for i, touchingPart in ipairs (game.Workspace:GetPartsInPart(spawnerPart)) do-- checks if something is 		already there, if it is then don't spawn anything
						if NaturalResourceStructureFolder:FindFirstChild(touchingPart.Parent.Name) then
							hasStuffSpawnedAlready  = true
						end
					end
					if hasStuffSpawnedAlready == false then
						local clone = desiredCrop:Clone( )
						clone.Parent = game.Workspace.NaturalResources
						clone:PivotTo(spawnerPart.CFrame) -- Moves the desiredd crop to the right spot
						clone.PrimaryPart.Anchored =  true
					end
				end 
			end
		end
	end
	--CONTINUED-- 
	--For Animals (Cows)
	for i , spawnerModel in ipairs(animalSpawnerPartFolder:GetChildren()) do-- for cows
		if spawnerModel:IsA("Model") then -- starts as models called crop triplets then then
			local desiredAnimal = replicatedAnimals:FindFirstChild("Cow_Model") -- chooses the animal, but all I want is cows
			for i, spawnerPart in ipairs(spawnerModel:GetChildren()) do -- for each part in the array of children of the model
				if spawnerPart:IsA("Part") then
					local hasStuffSpawnedAlready = false
					if hasStuffSpawnedAlready == false then
						if spawnerPart.Name ~= "NonSpawnPart" then -- theres a non spawnpart that helps with manipulating the spawnpoints in workspace
							--- since theres only one part per thing, set it to random number 1-3
							local randomNumber = math.random(minCows,maxCows) -- 1 to 3 cows?
							local amountOfCowsOnServer = getCowsCount()
							if amountOfCowsOnServer + randomNumber < maxCowsOnServer then -- make sure we aren't going over cap
								for i = 1, randomNumber do -- simple for loop
									local clone = desiredAnimal:Clone()
									if desiredAnimal.Name == "Cow_Model" then
										spawnCowToLocation(clone,spawnerPart.CFrame)
									end	
								end
							end																	
						end		
					end
				end 
			end
		end
	end
end
